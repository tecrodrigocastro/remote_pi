<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Plano 37 (decisão B, local-only desktop dev tool): o Cockpit spawna o
	     binário `pi` e lê pastas escolhidas pelo usuário. O sandbox do macOS
	     bloqueia ambos, então está DESLIGADO neste MVP (não é app de loja).
	     Reavaliar se/quando for distribuir pela App Store. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
